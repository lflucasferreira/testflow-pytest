{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["users"],
  "properties": {
    "users": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "email", "role"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "email": { "type": "string" },
          "role": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "total": { "type": "number" }
  },
  "additionalProperties": true
}
